{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./nuxt/*"],
      "@/*": ["./nuxt/*"]
    }
  },
  "include": [
    "nuxt/**/*.ts",
    "nuxt/**/*.vue"
  ]
}

